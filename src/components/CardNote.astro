---
interface Props {
  title: string;
  description?: string;
  date: string;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;
---

<article
  class="group relative bg-surface border-[length:var(--border-width)] border-border-subtle p-6 md:p-8 rounded-[var(--radius-2xl)] hover:shadow-[var(--shadow-lg)] hover:border-primary/20 transition-all duration-300 flex flex-col gap-4"
>
  <div class="flex items-center justify-between gap-4">
    <span
      class="text-[10px] font-mono uppercase tracking-[0.2em] text-text-muted opacity-60"
    >
      {date}
    </span>
    <div class="flex gap-2">
      {
        tags.map((tag) => (
          <span class="text-[9px] uppercase font-bold tracking-wider px-2 py-0.5 rounded-full bg-secondary/10 text-secondary border border-secondary/20">
            {tag}
          </span>
        ))
      }
    </div>
  </div>

  <h3
    class="text-2xl md:text-3xl font-serif font-black text-primary group-hover:text-secondary transition-colors leading-tight tracking-tight"
  >
    <a href={`/notes/${slug}`} class="before:absolute before:inset-0">
      {title}
    </a>
  </h3>

  {
    description && (
      <p class="text-sm md:text-base text-text-muted leading-relaxed line-clamp-3 italic opacity-80">
        {description}
      </p>
    )
  }

  <div
    class="mt-2 flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-primary opacity-0 group-hover:opacity-100 transition-opacity"
  >
    Leer nota <div class="i-ph-arrow-right"></div>
  </div>
</article>
