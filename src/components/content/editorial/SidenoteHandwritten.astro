---
interface Props {
  type?: 'comment' | 'correction' | 'idea';
}

const { type = 'comment' } = Astro.props;

const colors = {
  comment: 'var(--color-primary)',
  correction: 'var(--color-error, #e11d48)',
  idea: 'var(--color-secondary)'
};

const labels = {
  comment: 'Nota:',
  correction: 'Corr:',
  idea: 'Idea:'
};

const color = colors[type];
const label = labels[type];
---

<aside class="sidenote-wrapper">
  <span class="sidenote-anchor" aria-hidden="true">*</span>
  <div class="sidenote-content transition-all duration-300" style={`--accent-color: ${color}`}>
    <span class="sidenote-label">{label}</span>
    <slot />
  </div>
</aside>

<style>
  .sidenote-wrapper {
    display: inline;
    position: relative;
    vertical-align: baseline;
  }

  .sidenote-anchor {
    color: var(--accent-color);
    font-weight: bold;
    cursor: help;
    padding: 0 4px;
    font-family: "Architects Daughter", cursive;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .sidenote-wrapper:hover .sidenote-anchor {
    transform: scale(1.3) rotate(15deg);
    text-shadow: 0 0 8px var(--accent-color);
  }

  .sidenote-content {
    /* Baseline styles for mobile: inline callout */
    display: block;
    background: color-mix(in srgb, var(--accent-color), transparent 94%);
    border-left: 3px solid var(--accent-color);
    padding: 1rem;
    margin: 1.5rem 0;
    font-family: "Architects Daughter", cursive;
    font-size: 1rem;
    line-height: 1.5;
    position: relative;
    filter: url(#filter-sketch);
    box-shadow: 2px 2px 5px rgba(0,0,0,0.05);
    transform: rotate(-0.5deg);
    border-radius: 2px 10px 5px 12px / 5px 2px 15px 3px; /* Organic corners */
  }

  .sidenote-label {
    display: block;
    font-weight: bold;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 4px;
    opacity: 0.7;
    color: var(--accent-color);
  }

  /* Desktop layout: floating in margins */
  @media (min-width: 1200px) {
    .sidenote-content {
      position: absolute;
      top: -0.5rem;
      right: calc(-280px - 3rem);
      width: 280px;
      margin: 0;
      z-index: 10;
      opacity: 0;
      visibility: hidden;
      transform: translateX(10px) rotate(1deg);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      background: color-mix(in srgb, var(--accent-color), transparent 96%);
      backdrop-filter: blur(2px);
    }
    
    /* Arrow connector */
    .sidenote-content::before {
      content: "";
      position: absolute;
      top: 1.5rem;
      left: -2.5rem;
      width: 2.5rem;
      height: 20px;
      border-bottom: 2px solid var(--accent-color);
      border-left: 2px solid var(--accent-color);
      border-radius: 0 0 0 15px;
      opacity: 0.3;
      transform: skewY(-5deg);
      pointer-events: none;
    }
    
    /* Small scribble tip for the arrow */
    .sidenote-content::after {
      content: "";
      position: absolute;
      top: 1.5rem;
      left: -2.6rem;
      width: 8px;
      height: 8px;
      border-right: 2px solid var(--accent-color);
      border-top: 2px solid var(--accent-color);
      transform: rotate(45deg);
      opacity: 0.3;
    }

    .sidenote-wrapper:hover .sidenote-content {
      opacity: 1;
      visibility: visible;
      transform: translateX(0) rotate(-1.5deg);
    }
  }

  /* Dark mode support */
  :global(.dark) .sidenote-content {
    background: color-mix(in srgb, var(--accent-color), transparent 90%);
    box-shadow: 2px 4px 12px rgba(0,0,0,0.2);
  }
</style>
