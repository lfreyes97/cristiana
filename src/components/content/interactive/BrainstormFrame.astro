---
interface Props {
  x?: number;
  y?: number;
  scale?: number;
  rotate?: number;
  id?: string;
}

const { x, y, scale = 1, rotate, id = Math.random().toString(36).substr(2, 9) } = Astro.props;
const isAuto = x === undefined && y === undefined;
const finalX = x || 0;
const finalY = y || 0;
const finalRotate = rotate || 0;
---

<div 
  class="canvas-frame" 
  data-frame 
  data-x={finalX} 
  data-y={finalY} 
  data-scale={scale} 
  data-rotate={finalRotate}
  data-auto={isAuto ? "true" : "false"}
  data-id={id}
  style={`top: ${finalY}px; left: ${finalX}px; transform: translate(-50%, -50%) scale(${scale}) rotate(${finalRotate}deg);`}
>
  <div class="frame-content">
    <slot />
  </div>
</div>

<style>
  .canvas-frame {
    position: absolute;
    width: max-content;
    min-width: 300px;
    max-width: 500px;
    transform-origin: center center;
    pointer-events: auto;
    margin: auto;
  }

  .frame-content {
    background: var(--color-bg);
    padding: 2.5rem 3rem;
    border: 1px solid var(--color-border);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
    border-radius: var(--radius-md);
    position: relative;
  }


</style>
