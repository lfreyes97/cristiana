---
interface Props {
  author?: string;
  role?: string;
}

const { author = "Luis F. Reyes", role = "Editor & Curador" } = Astro.props;
---

<div class="mt-16 pt-8 border-t border-border">
  <div class="flex items-center gap-4">
    <div
      class="w-14 h-14 bg-secondary rounded-full flex items-center justify-center text-white font-display font-bold text-2xl"
    >
      {author.charAt(0)}
    </div>
    <div>
      <p class="font-bold text-primary text-lg font-display">
        {author}
      </p>
      <p class="text-sm opacity-60 font-sans uppercase tracking-wider">
        {role}
      </p>
    </div>
  </div>
</div>
