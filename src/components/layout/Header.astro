---
import ThemeSwitcher from "../ui/ThemeSwitcher/ThemeSwitcher.svelte";

const currentPath = Astro.url.pathname;
---

<!-- CENTERED HEADER (main, scrolls away) -->
<header id="main-header" class="relative w-full py-10 px-6">
  <div class="w-full max-w-7xl mx-auto flex flex-col items-center gap-8">
    <!-- Logo -->
    <a
      href="/"
      class="text-4xl md:text-7xl font-display font-black tracking-tighter text-primary"
    >
      Cristianamente.
    </a>

    <!-- Pill Nav -->
    <nav
      class="w-auto overflow-x-auto px-4 py-2 md:px-8 md:py-3 bg-surface border-[length:var(--border-width)] border-border rounded-[var(--radius-pill)] shadow-[var(--shadow-md)] flex items-center gap-3 md:gap-6 justify-center"
    >
      <a
        href="/"
        class:list={[
          "text-[10px] md:text-xs font-black uppercase tracking-widest transition-colors whitespace-nowrap hidden md:block",
          currentPath === "/"
            ? "text-primary"
            : "text-text-muted hover:text-primary",
        ]}>Home</a
      >
      <div class="hidden md:block w-1.5 h-1.5 bg-border rotate-45"></div>
      <a
        href="/blog"
        class:list={[
          "text-[10px] md:text-xs font-black uppercase tracking-widest transition-colors whitespace-nowrap",
          currentPath.startsWith("/blog")
            ? "text-primary"
            : "text-text-muted hover:text-primary",
        ]}>Ensayos</a
      >
      <div class="w-1 h-1 md:w-1.5 md:h-1.5 bg-border rotate-45"></div>
      <a
        href="/notes"
        class:list={[
          "text-[10px] md:text-xs font-black uppercase tracking-widest transition-colors whitespace-nowrap",
          currentPath.startsWith("/notes")
            ? "text-primary"
            : "text-text-muted hover:text-primary",
        ]}>Notas</a
      >
      <div class="w-1 h-1 md:w-1.5 md:h-1.5 bg-border rotate-45"></div>
      <a
        href="/about"
        class:list={[
          "text-[10px] md:text-xs font-black uppercase tracking-widest transition-colors whitespace-nowrap",
          currentPath === "/about"
            ? "text-primary"
            : "text-text-muted hover:text-primary",
        ]}>Acerca</a
      >
    </nav>
  </div>
</header>

<!-- STICKY HEADER (appears when centered header scrolls out) -->
<div
  id="sticky-header"
  class="fixed top-0 left-0 w-full z-50 bg-bg/95 backdrop-blur-md border-b border-border-subtle shadow-sm -translate-y-full opacity-0 invisible transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a
      href="/"
      class="text-xl font-serif font-black tracking-tighter text-primary"
    >
      Cristianamente.
    </a>

    <nav class="flex items-center gap-4 md:gap-6">
      <!-- Hidden on very small screens, shown as text on tablet/desktop -->
      <a
        href="/blog"
        class:list={[
          "text-[10px] md:text-xs font-bold uppercase tracking-wider transition-colors",
          currentPath.startsWith("/blog")
            ? "text-primary"
            : "text-text-muted hover:text-primary",
        ]}>Ensayos</a
      >
      <a
        href="/about"
        class:list={[
          "text-[10px] md:text-xs font-bold uppercase tracking-wider transition-colors",
          currentPath === "/about"
            ? "text-primary"
            : "text-text-muted hover:text-primary",
        ]}>Acerca</a
      >
      <div class="w-px h-4 md:h-5 bg-border-subtle"></div>
      <ThemeSwitcher client:only="svelte" />
    </nav>
  </div>
</div>

<script>
  const mainHeader = document.getElementById("main-header");
  const stickyHeader = document.getElementById("sticky-header");

  if (mainHeader && stickyHeader) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          // Main header visible → hide sticky
          stickyHeader.classList.add(
            "-translate-y-full",
            "opacity-0",
            "invisible",
          );
          stickyHeader.classList.remove(
            "translate-y-0",
            "opacity-100",
            "visible",
          );
        } else {
          // Main header gone → show sticky
          stickyHeader.classList.remove(
            "-translate-y-full",
            "opacity-0",
            "invisible",
          );
          stickyHeader.classList.add("translate-y-0", "opacity-100", "visible");
        }
      },
      { threshold: 0 },
    );

    observer.observe(mainHeader);
  }
</script>
