---
interface Props {
  title?: string;
  content?: string;
  footer?: string;
}

const { title, content, footer } = Astro.props;
---

{
  (title || content || footer) && (
    <aside class="md:col-span-4 md:sticky md:top-32 self-start order-2 md:order-1">
      <div class="bg-surface p-8 rounded-[var(--radius-md)] border-[length:var(--border-width)] border-border shadow-[var(--shadow-sm)]">
        {title && (
          <h3 class="font-display font-bold text-primary mb-6 text-lg tracking-tight">
            {title}
          </h3>
        )}
        {content && (
          <p class="text-sm text-text-muted leading-relaxed font-sans mb-6">
            {content}
          </p>
        )}
        {footer && (
          <>
            <div class="h-px w-full bg-border mb-6" />
            <p class="text-xs text-text-muted/60 font-mono italic">{footer}</p>
          </>
        )}
      </div>
    </aside>
  )
}
