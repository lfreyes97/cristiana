---
import Layout from "./Layout.astro";
import ReadingProgressHeader from "../components/layout/ReadingProgressHeader.svelte";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  category: string;
  date: string;
  description: string;
  headings?: { depth: number; slug: string; text: string }[];
  slug?: string;
}

const {
  title,
  category,
  date,
  description,
  headings = [],
  slug,
} = Astro.props;

const ogImage = slug ? `/og/${slug}.png` : undefined;
---

<Layout title={title} description={description} ogImage={ogImage}>
  <ReadingProgressHeader client:load title={title} headings={headings} />

  <main class="note-container pt-8 pb-24 min-h-screen overflow-x-hidden md:overflow-x-visible">
    <div class="max-w-4xl mx-auto px-6 relative">
      <!-- Notebook Background Decoration (Desktop) -->
      <div class="hidden xl:block absolute -left-24 top-0 bottom-0 w-1 bg-secondary/20 shadow-[4px_0_0_0_rgba(var(--color-secondary-rgb),0.1),8px_0_0_0_rgba(var(--color-secondary-rgb),0.05)]"></div>

      <article class="relative">
        <header class="mb-12 text-left">
          <div class="flex items-center justify-between mb-4 print:hidden">
            <div class="flex items-center gap-4">
              <span class="handwritten text-secondary text-sm font-bold uppercase tracking-widest">
                {category}
              </span>
              <span class="w-1 h-1 bg-border rounded-full"></span>
              <span class="handwritten text-xs text-text opacity-60">
                {date}
              </span>
            </div>

            <button 
              onclick="window.print()" 
              class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-tighter text-text-muted hover:text-primary transition-all px-3 py-1 border border-border-subtle rounded-full hover:bg-bg-offset"
            >
              <div class="i-ph-printer"></div>
              <span>Imprimir / PDF</span>
            </button>
          </div>

          <h1 class="handwritten-title text-4xl md:text-6xl font-black text-primary mb-6 leading-tight tracking-tight">
            {title}
          </h1>

          <p class="handwritten text-xl text-text opacity-80 leading-relaxed max-w-2xl">
            {description}
          </p>
          
          <div class="w-full h-px bg-border mt-8 opacity-50 filter-sketch"></div>
        </header>

        <div class="note-prose prose prose-lg prose-slate dark:prose-invert 
                    prose-p:font-serif prose-p:leading-relaxed prose-p:text-text/90
                    prose-headings:font-display prose-headings:text-primary
                    prose-blockquote:border-none prose-blockquote:p-0
                    relative">
          <slot />
        </div>

        <div class="mt-24 pt-12 border-t border-border flex justify-between items-center filter-sketch">
          <a
            href="/notes"
            class="handwritten inline-flex items-center gap-2 text-sm font-bold text-text hover:text-secondary transition-colors opacity-60 hover:opacity-100"
          >
            <div class="i-ph-arrow-left"></div> Volver a las notas
          </a>
        </div>
      </article>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .handwritten {
    font-family: "Architects Daughter", cursive !important;
  }
  
  .handwritten-title {
    font-family: "Kalam", cursive !important;
    filter: url(#filter-sketch);
  }

  .note-container {
    --paper-line-color: color-mix(in srgb, var(--color-border), transparent 80%);
    background-image: repeating-linear-gradient(
      transparent,
      transparent 31px,
      var(--paper-line-color) 31px,
      var(--paper-line-color) 32px
    );
    background-size: 100% 32px;
    background-attachment: local;
  }

  /* Specific prose overrides for the note feel */
  .note-prose {
    max-width: 65ch;
  }

  .filter-sketch {
    filter: url(#filter-sketch);
  }

  /* Make sure the main text remains legible but feels organic */
  .note-prose p {
    margin-bottom: 2rem;
  }

  /* Right margin space for sidenotes on desktop */
    @media (min-width: 1200px) {
      .note-container article {
        padding-right: 50px; /* Space to move the body left slightly */
      }
    }

    /* ── Uniform Output (Print Styles) ─────────────────────────── */
    @media print {
      @page {
        margin: 2.5cm;
        size: A4;
      }

      :root {
        --color-bg: white !important;
        --color-text: black !important;
        --color-primary: black !important;
      }

      body, .note-container {
        background: white !important;
        background-image: none !important;
        padding: 0 !important;
        color: black !important;
      }

      nav, footer, .print-button, .print\:hidden, [class*="i-ph-arrow"] {
        display: none !important;
      }

      .note-container {
        min-height: auto !important;
      }

      .max-w-4xl {
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      /* Typst/Editorial Aesthetic */
      .handwritten-title {
        font-family: "EB Garamond", serif !important;
        text-align: center;
        font-size: 2.5rem !important;
        filter: none !important;
        margin-top: 1cm;
      }

      .handwritten {
        font-family: "EB Garamond", serif !important;
        text-transform: none !important;
        letter-spacing: normal !important;
      }

      .note-prose {
        max-width: 100% !important;
        text-align: justify;
        hyphens: auto;
        font-size: 11pt;
        line-height: 1.5;
        color: black !important;
      }

      .note-prose p {
        margin-bottom: 1.2em;
      }

      /* Ensure Typst SVGs are crisp in print */
      .typst-doc {
        filter: grayscale(1) contrast(1.2);
        color: black !important;
      }
      
      .typst-doc path {
        fill: black !important;
      }
    }
  </style>
