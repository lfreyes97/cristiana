---
import { type CollectionEntry, getCollection, render } from "astro:content";
import NoteLayout from "../../layouts/NoteLayout.astro";
import Mark from "../../components/Notes/Mark.astro";
import Sidenote from "../../components/Notes/Sidenote.astro";
import PostIt from "../../components/Notes/PostIt.astro";
import HandwrittenQuote from "../../components/Notes/HandwrittenQuote.astro";
import Presentation from "../../components/Notes/BrainstormCanvas.svelte";
import Frame from "../../components/Notes/BrainstormFrame.astro";

export async function getStaticPaths() {
  const notes = await getCollection("notas");
  return notes.map((note) => ({
    params: { slug: note.id },
    props: note,
  }));
}
type Props = CollectionEntry<"notas">;

const note = Astro.props;
const { Content, headings } = await render(note);

const date = note.data.pubDate.toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const components = {
  Mark,
  Sidenote,
  PostIt,
  HandwrittenQuote,
  Presentation,
  Frame,
};
---

<NoteLayout
  title={note.data.title}
  category="Nota"
  date={date}
  description={note.data.description || ""}
  headings={headings}
>
  <Content components={components} />
</NoteLayout>
