---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import { getCollection } from "astro:content";
import CardNote from "../../components/cards/CardNote.astro";

const notes = (await getCollection("notas"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((note) => ({
    title: note.data.title,
    description: note.data.description,
    tags: note.data.tags,
    date: note.data.pubDate.toLocaleDateString("es-ES", {
      year: "numeric",
      month: "short",
      day: "numeric",
    }),
    slug: note.id,
  }));
---

<Layout title="Notas - Cristianamente">
  <Header />

  <main class="min-h-screen">
    <section class="py-24">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-24">
          <span
            class="text-secondary font-bold tracking-widest uppercase text-[10px] mb-3 block"
            >Bitácora</span
          >
          <h1
            class="text-5xl md:text-6xl font-serif font-black text-primary mb-6 tracking-tighter"
          >
            Notas
          </h1>
          <p
            class="text-xl text-text opacity-80 font-serif italic leading-relaxed max-w-xl mx-auto"
          >
            Fragmentos de pensamiento, reflexiones diarias y semillas de futuros
            ensayos.
          </p>
          <div class="w-12 h-1 bg-secondary mx-auto mt-8 opacity-40"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
          {
            notes.map((note) => (
              <CardNote
                title={note.title}
                description={note.description}
                tags={note.tags}
                date={note.date}
                slug={note.slug}
              />
            ))
          }
        </div>

        {
          notes.length === 0 && (
            <p class="text-center text-text-muted italic py-12">
              No hay notas publicadas aún.
            </p>
          )
        }
      </div>
    </section>
  </main>

  <Footer />
</Layout>
