{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cristiana",
  "compatibility_date": "2026-04-03",
  "routes": [
    {
      "pattern": "cristianamente.xyz",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  }
}
